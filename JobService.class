.root {
    -fx-font-family: "Segoe UI", "Microsoft YaHei", "PingFang SC", sans-serif;
    -fx-background-color: linear-gradient(to bottom right, #f7f9fc, #eef3f9);
}

.page-root {
    -fx-background-color: linear-gradient(to bottom right, #f7f9fc, #eef3f9);
}

.page-shell {
    -fx-max-width: 1080px;
    -fx-alignment: top-center;
}

.page-header {
    -fx-spacing: 6;
}

.page-title {
    -fx-font-size: 28px;
    -fx-font-weight: 700;
    -fx-text-fill: #1f2d3d;
}

.section-title {
    -fx-font-size: 22px;
    -fx-font-weight: 700;
    -fx-text-fill: #1f2d3d;
}

.page-subtitle {
    -fx-font-size: 13px;
    -fx-text-fill: #607086;
}

.hero-card,
.card,
.form-card,
.list-card,
.dashboard-card,
.resume-card,
.info-card {
    -fx-background-color: rgba(255,255,255,0.96);
    -fx-background-radius: 18;
    -fx-border-color: #dbe5f0;
    -fx-border-radius: 18;
    -fx-padding: 22;
    -fx-effect: dropshadow(gaussian, rgba(31,45,61,0.08), 18, 0.18, 0, 8);
}

.hero-card {
    -fx-max-width: 460px;
}

.form-label {
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-text-fill: #334155;
}

.value-label {
    -fx-font-size: 13px;
    -fx-text-fill: #0f172a;
}

.muted-label {
    -fx-font-size: 12px;
    -fx-text-fill: #64748b;
}

.status-success {
    -fx-text-fill: #17803d;
    -fx-font-weight: 600;
}

.status-error {
    -fx-text-fill: #c62828;
    -fx-font-weight: 600;
}

.text-field,
.password-field,
.text-area,
.combo-box {
    -fx-background-color: #f8fbff;
    -fx-background-radius: 12;
    -fx-border-color: #cfd9e4;
    -fx-border-radius: 12;
    -fx-padding: 10 12;
    -fx-font-size: 13px;
}

.text-field:focused,
.password-field:focused,
.text-area:focused,
.combo-box:focused {
    -fx-border-color: #4f7cff;
    -fx-background-color: white;
}

.button {
    -fx-background-color: #e9eef6;
    -fx-text-fill: #1e293b;
    -fx-background-radius: 12;
    -fx-padding: 10 18;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-cursor: hand;
}

.button:hover {
    -fx-background-color: #dde6f3;
}

.button:pressed {
    -fx-background-color: #d2ddeb;
}

.primary-button {
    -fx-background-color: linear-gradient(to right, #4f7cff, #3b82f6);
    -fx-text-fill: white;
}

.primary-button:hover {
    -fx-background-color: linear-gradient(to right, #4671eb, #3475dd);
}

.secondary-button {
    -fx-background-color: #eef4ff;
    -fx-text-fill: #1d4ed8;
}

.secondary-button:hover {
    -fx-background-color: #dfe9ff;
}

.success-button {
    -fx-background-color: linear-gradient(to right, #1fa971, #178d60);
    -fx-text-fill: white;
}

.success-button:hover {
    -fx-background-color: linear-gradient(to right, #1a9564, #157f57);
}

.danger-button {
    -fx-background-color: #fff1f2;
    -fx-text-fill: #be123c;
}

.danger-button:hover {
    -fx-background-color: #ffe4e6;
}

.chip {
    -fx-background-color: #edf2ff;
    -fx-background-radius: 999;
    -fx-padding: 4 10;
    -fx-text-fill: #3658c9;
    -fx-font-size: 12px;
    -fx-font-weight: 600;
}

.job-card,
.application-card {
    -fx-background-color: white;
    -fx-background-radius: 14;
    -fx-border-color: #dce5ef;
    -fx-border-radius: 14;
    -fx-padding: 16;
}

.job-title {
    -fx-font-size: 16px;
    -fx-font-weight: 700;
    -fx-text-fill: #0f172a;
}

.small-pill {
    -fx-background-color: #f1f5f9;
    -fx-background-radius: 999;
    -fx-padding: 4 10;
    -fx-text-fill: #334155;
    -fx-font-size: 12px;
}

.progress-bar {
    -fx-accent: #3b82f6;
}

.separator .line {
    -fx-border-color: #d9e2ee;
}

.scroll-pane {
    -fx-background-color: transparent;
}

.scroll-pane > .viewport {
    -fx-background-color: transparent;
}

.dashboard-action {
    -fx-pref-width: 250px;
    -fx-pref-height: 44px;
}
